{
	"name": "lcov-reporter-action",
	"version": "0.2.20",
	"description": "Comments a pull request with the lcov code coverage",
	"license": "MIT",
	"author": "Romeo Van Snick",
	"repository": "https://github.com/romeovs/lcov-reporter-action",
	"keywords": [
		"actions",
		"pull-request",
		"comment",
		"message"
	],
	"main": "index.js",
	"scripts": {
		"build": "rollup -c",
		"test": "node --experimental-vm-modules ./node_modules/.bin/jest --passWithNoTests --coverage",
		"local": "node src/cli.js",
		"format": "prettier --write src/*.js src/**/*.js"
	},
	"dependencies": {
		"@actions/core": "^1.11.1",
		"@actions/github": "^6.0.0",
		"lcov-parse": "^1.0.0"
	},
	"devDependencies": {
		"@jest/globals": "^29.7.0",
		"@rollup/plugin-commonjs": "^28.0.0",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"jest": "^29.7.0",
		"prettier": "^3.4.0",
		"rollup": "^4.28.0",
		"rollup-plugin-node-externals": "^8.0.0"
	},
	"type": "module",
	"jest": {
		"transform": {},
		"testMatch": [
			"<rootDir>/src/*_test.js",
			"<rootDir>/src/**/*_test.js"
		]
	},
	"prettier": {
		"semi": false,
		"useTabs": true,
		"trailingComma": "all"
	}
}